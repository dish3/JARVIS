# Sarvam AI API Key (for Indian context STT/TTS)
SARVAM_API_KEY=your_sarvam_api_key_here

# Groq API Keys (Primary and Rotation Pool)
GROQ_API_KEY=your_groq_api_key_here

# AI Model Configuration
GROQ_MODEL=llama-3.3-70b-versatile
OLLAMA_MODEL=phi3.5
AI_BACKEND=auto  # groq | ollama | auto (try groq first, fallback to ollama)

# Google Gemini API Key
GEMINI_API_KEY=your_gemini_api_key_here


# OpenRouter API Key (for fallback models and reasoning)
OPENROUTER_API_KEY=your_openrouter_api_key_here

# LinkedIn Automation (Optional)
LINKEDIN_EMAIL=your_linkedin_email@example.com
LINKEDIN_PASSWORD=your_linkedin_password
